{
	"compilerOptions": {
		"baseUrl": ".",
		"moduleResolution": "Bundler",
		"paths": {
			"@/*": ["./src/*"],
			"@/assets/*": ["./assets/*"],
			"@env": ["env.ts"]
		},
		"strict": true
	},
	"extends": "expo/tsconfig.base",
	"include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}

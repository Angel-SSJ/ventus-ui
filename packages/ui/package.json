		"format": "pnpm exec biome format --write .",
		"generate primitive": "plop --plopfile ./primitive.plopfile.js",
		"lint": "pnpm exec biome lint --write .",
		"test": "jest",
		"test:watch": "jest --watch",
		"typecheck": "tsc --noEmit"

{
  "author": "Angel Ramirez <angelgabriel.16ra@gmail.com> (https://github.com/Angel-SSJ)",
  "bugs": {
    "url": "https://github.com/Angel-SSJ/react-native-ventus-ui/issues"
  },
  "create-react-native-library": {
    "languages": "js",
    "tools": [
      "biome",
      "jest",
      "lefthook"
    ],
    "type": "library",
    "version": "0.56.1"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "clsx": "^2.1.1",
    "expo": "~55.0.5",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "tailwind-merge": "^2.6.1",
    "tailwind-variants": "^0.2.1"
  },
  "description": "A high-quality UI Kit for React Native based on Tailwind CSS.",
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@changesets/apply-release-plan": "^7.1.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-community/slider": "^5.1.2",
    "@react-native/babel-preset": "0.83.2",
    "@release-it/conventional-changelog": "^10.0.5",
    "@storybook/addon-ondevice-actions": "^10.2.3",
    "@storybook/addon-ondevice-backgrounds": "^10.2.3",
    "@storybook/addon-ondevice-controls": "^10.2.3",
    "@storybook/react": "^10.2.3",
    "@storybook/react-native": "^10.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "babel-plugin-module-resolver": "^5.0.2",
    "commitlint": "^20.4.3",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "del-cli": "^7.0.0",
    "jest": "^30.2.0",
    "lefthook": "^2.1.3",
    "react": "19.2.4",
    "react-native": "0.83.2",
    "react-test-renderer": "19.2.0",
    "storybook": "^10.2.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "default": "./lib/module/index.js",
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts"
    },
    "./package.json": "./package.json",
    "./theme-preset": "./theme-preset.js"
  },
  "files": [
    "src",
    "lib",
    "theme-preset.js",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "homepage": "https://github.com/Angel-SSJ/react-native-ventus-ui#readme",
  "jest": {
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ],
    "preset": "react-native"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "license": "MIT",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "name": "react-native-ventus-ui",
  "peerDependencies": {
    "expo": ">=54.0.0",
    "nativewind": "^4.0.0",
    "react": ">=19.0.0",
    "react-native": ">=0.83.2",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=4.0.0",
    "react-native-safe-area-context": ">=4.0.0",
    "react-native-svg": "*"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Angel-SSJ/react-native-ventus-ui.git"
  },
  "scripts": {
    "biome": "pnpm exec biome",
    "build": "pnpm --filter apps run build",
    "build:android": "pnpm --filter apps run build:android",
    "build:ios": "pnpm --filter apps run build:ios",
    "changeset": "changeset",
    "check": "pnpm exec biome check --write .",
    "clean": "del-cli lib",
    "demo": "pnpm --filter apps run demo",
    "format": "pnpm exec biome format --write .",
    "lint": "pnpm exec biome lint --write .",
    "storybook:generate": "pnpm --filter apps run storybook-generate",
    "test": "jest --passWithNoTests",
    "test:ui": "pnpm --filter @ventus-ui/react-native test",
    "typecheck": "tsc",
    "version-packages": "changeset version"
  },
  "types": "./lib/typescript/src/index.d.ts",
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}
